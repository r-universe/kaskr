[submodule ".registry"]
	path = .registry
	url = https://github.com/kaskr/kaskr.r-universe.dev
	branch = HEAD
[submodule "RTMB"]
	path = RTMB
	url = https://github.com/kaskr/RTMB
	subdir = RTMB
[submodule "RTMBode"]
	path = RTMBode
	url = https://github.com/kaskr/RTMB
	subdir = RTMBode
[submodule "RTMBp"]
	path = RTMBp
	url = https://github.com/kaskr/RTMB
	branch = RTMBp
	subdir = RTMBp
[submodule "TMB"]
	path = TMB
	url = https://github.com/kaskr/adcomp
	subdir = TMB
[submodule "tmbstan"]
	path = tmbstan
	url = https://github.com/kaskr/tmbstan
	subdir = tmbstan
